---
import Layout from '../layouts/Layout.astro';
import data from '../data/services.json';
---

<Layout title="Služby" description="Vstřikování termoplastů, výroba forem, montáž a kompletace plastových dílů.">
  <!-- Page Header -->
  <section class="relative bg-primary pt-28 pb-12 md:pt-32 md:pb-16 overflow-hidden">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-[120px]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-accent"></span>
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Naše služby</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-white tracking-tight">{data.pageTitle}</h1>
      <p class="text-white/50 mt-4 max-w-xl text-lg">
        {data.pageDescription}
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-10 md:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-10">
        {data.services.map((service, i) => (
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center reveal">
            {i % 2 === 0 ? (
              <>
                <div>
                  <div class="flex items-center gap-3 mb-6">
                    <span class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center text-accent font-black text-sm">{service.number}</span>
                    <span class="text-xs uppercase tracking-widest text-gray-medium font-semibold">{service.tag}</span>
                  </div>
                  <h2 class="text-3xl md:text-4xl font-black text-primary tracking-tight mb-5">{service.title}</h2>
                  <p class="text-gray-medium leading-relaxed mb-6">{service.description}</p>
                  <ul class="space-y-3">
                    {service.features.map(feature => (
                      <li class="flex items-center gap-3 text-sm">
                        <span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
                        <span class="text-gray-medium">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="rounded-3xl h-72 lg:h-96 overflow-hidden border border-gray-100">
                  <img src={service.image} alt={service.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              </>
            ) : (
              <>
                <div class="order-2 lg:order-1 rounded-3xl h-72 lg:h-96 overflow-hidden border border-gray-100">
                  <img src={service.image} alt={service.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="order-1 lg:order-2">
                  <div class="flex items-center gap-3 mb-6">
                    <span class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center text-accent font-black text-sm">{service.number}</span>
                    <span class="text-xs uppercase tracking-widest text-gray-medium font-semibold">{service.tag}</span>
                  </div>
                  <h2 class="text-3xl md:text-4xl font-black text-primary tracking-tight mb-5">{service.title}</h2>
                  <p class="text-gray-medium leading-relaxed mb-6">{service.description}</p>
                  <ul class="space-y-3">
                    {service.features.map(feature => (
                      <li class="flex items-center gap-3 text-sm">
                        <span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
                        <span class="text-gray-medium">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-10 bg-primary overflow-hidden">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl md:text-4xl font-black text-white tracking-tight">Potřebujete plastové díly?</h2>
      <p class="text-white/50 max-w-lg mx-auto mt-4">
        Pošlete nám poptávku a do 48 hodin připravíme nezávaznou nabídku.
      </p>
      <a href="/kontakt" class="inline-flex bg-accent text-primary font-semibold px-10 py-4 rounded-full transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/25 text-sm uppercase tracking-wide mt-8 pulse-cta">
        Poslat poptávku
      </a>
    </div>
  </section>
</Layout>
