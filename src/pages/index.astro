---
import Layout from '../layouts/Layout.astro';
import hp from '../data/homepage.json';
---

<Layout title="Lisování plastů a výroba plastových dílů">
  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center bg-primary overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 grid-pattern"></div>
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-accent/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 -left-32 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 w-full">
      <div class="max-w-4xl">
        <div class="flex items-center gap-3 mb-8">
          <span class="w-12 h-px bg-accent"></span>
          <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">{hp.subtitle}</span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-8xl font-black text-white leading-[0.95] mb-8 tracking-tight">
          {hp.heading1}<br>
          {hp.heading2}<br>
          <span class="text-gradient">{hp.heading3}</span>
        </h1>

        <p class="text-lg md:text-xl text-white/60 leading-relaxed mb-12 max-w-xl">
          {hp.description}
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/sluzby" class="group bg-accent text-primary font-semibold px-8 py-4 rounded-full transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/25 text-sm uppercase tracking-wide flex items-center gap-3">
            Naše služby
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/kontakt" class="border border-white/20 text-white hover:border-accent hover:text-accent font-medium px-8 py-4 rounded-full transition-all duration-300 text-sm uppercase tracking-wide">
            Kontaktujte nás
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative -mt-1 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-primary-light rounded-2xl -mt-12 relative z-10 shadow-2xl shadow-primary/20">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
          {hp.stats.map((stat, i) => (
            <div class={`p-8 text-center reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
              <div class={`text-3xl md:text-4xl font-black ${i === hp.stats.length - 1 ? 'text-white' : 'text-accent'}`}>{stat.value}</div>
              <div class="text-xs text-white/50 mt-2 uppercase tracking-widest">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-6 reveal">
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Služby</span>
        <h2 class="text-4xl md:text-5xl font-black text-primary mt-3 tracking-tight">Co děláme</h2>
        <p class="text-gray-medium mt-4 text-lg">Komplexní řešení v oblasti zpracování plastů od návrhu po hotový výrobek.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Service 1 -->
        <div class="group relative bg-surface rounded-3xl p-10 transition-all duration-500 hover:bg-primary hover:shadow-2xl hover:shadow-primary/20 reveal">
          <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mb-6 transition-colors duration-500 group-hover:bg-accent/20">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary mb-3 transition-colors duration-500 group-hover:text-white">Vstřikování termoplastů</h3>
          <p class="text-gray-medium text-sm leading-relaxed transition-colors duration-500 group-hover:text-white/70">
            Výroba plastových dílů na moderních lisech Arburg s uzavírací silou od 50 do 800 tun. Zpracování přes 300 typů materiálů.
          </p>
          <div class="mt-6 flex items-center gap-2 text-accent text-sm font-semibold opacity-0 transition-all duration-500 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
            Více info
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </div>
        </div>

        <!-- Service 2 -->
        <div class="group relative bg-surface rounded-3xl p-10 transition-all duration-500 hover:bg-primary hover:shadow-2xl hover:shadow-primary/20 reveal reveal-delay-1">
          <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mb-6 transition-colors duration-500 group-hover:bg-accent/20">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary mb-3 transition-colors duration-500 group-hover:text-white">Nástrojárna</h3>
          <p class="text-gray-medium text-sm leading-relaxed transition-colors duration-500 group-hover:text-white/70">
            Vlastní výroba a údržba vstřikovacích forem. Konstrukční návrhy CAD/CAM a technická podpora při vývoji.
          </p>
          <div class="mt-6 flex items-center gap-2 text-accent text-sm font-semibold opacity-0 transition-all duration-500 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
            Více info
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </div>
        </div>

        <!-- Service 3 -->
        <div class="group relative bg-surface rounded-3xl p-10 transition-all duration-500 hover:bg-primary hover:shadow-2xl hover:shadow-primary/20 reveal reveal-delay-2">
          <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mb-6 transition-colors duration-500 group-hover:bg-accent/20">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary mb-3 transition-colors duration-500 group-hover:text-white">Kontrola kvality</h3>
          <p class="text-gray-medium text-sm leading-relaxed transition-colors duration-500 group-hover:text-white/70">
            Důsledná kontrola v každé fázi výroby. 3D měření, vizuální kontrola a funkční testy každého dílu.
          </p>
          <div class="mt-6 flex items-center gap-2 text-accent text-sm font-semibold opacity-0 transition-all duration-500 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
            Více info
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-10 md:py-14 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">O společnosti</span>
          <h2 class="text-4xl md:text-5xl font-black text-primary mt-3 tracking-tight leading-tight">
            Spolehlivý partner<br>pro vaši výrobu
          </h2>
          <p class="text-gray-medium leading-relaxed mt-6">
            Firma Union Power s.r.o. působí na trhu od roku 2010. Specializujeme se na lisování a vstřikování plastů pro průmyslové odběratele. Díky modernímu strojnímu parku Arburg realizujeme zakázky od prototypů po velkosériovou produkci.
          </p>
          <div class="flex flex-wrap gap-4 mt-8">
            <a href="/o-nas" class="group inline-flex items-center gap-3 bg-primary text-white font-semibold px-7 py-3.5 rounded-full hover:bg-primary-light transition-all duration-300 text-sm uppercase tracking-wide">
              Více o nás
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal">
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Vlastní nástrojárna</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Kompletní výroba a servis forem</p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Lisy Arburg</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Špičkové vstřikovací technologie</p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Flexibilní výroba</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Od prototypů po velké série</p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Certifikovaná kvalita</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Kontrola v každé fázi</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6 reveal">
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Odvětví</span>
        <h2 class="text-4xl md:text-5xl font-black text-primary mt-3 tracking-tight">Komu dodáváme</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 reveal">
        <div class="text-center p-8 rounded-2xl border border-gray-100 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
          </div>
          <h3 class="font-bold text-primary text-sm">Automotive</h3>
          <p class="text-xs text-gray-medium mt-1">Automobilový průmysl</p>
        </div>
        <div class="text-center p-8 rounded-2xl border border-gray-100 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-bold text-primary text-sm">Elektrotechnika</h3>
          <p class="text-xs text-gray-medium mt-1">Elektronické komponenty</p>
        </div>
        <div class="text-center p-8 rounded-2xl border border-gray-100 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-primary text-sm">Strojírenství</h3>
          <p class="text-xs text-gray-medium mt-1">Průmyslové komponenty</p>
        </div>
        <div class="text-center p-8 rounded-2xl border border-gray-100 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="font-bold text-primary text-sm">Stavebnictví</h3>
          <p class="text-xs text-gray-medium mt-1">Stavební prvky</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-10 md:py-14 bg-primary overflow-hidden">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent/10 rounded-full blur-[150px]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Spolupráce</span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mt-4 tracking-tight">
        Máte projekt?
      </h2>
      <p class="text-white/50 max-w-lg mx-auto mt-6 text-lg">
        Připravíme nezávaznou nabídku do 48 hodin. Společně najdeme optimální řešení.
      </p>
      <a href="/kontakt" class="inline-flex bg-accent text-primary font-semibold px-10 py-4 rounded-full transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/25 text-sm uppercase tracking-wide mt-10 pulse-cta">
        Nezávazná poptávka
      </a>
    </div>
  </section>
</Layout>
