---
import Layout from '../layouts/Layout.astro';
import data from '../data/about.json';
---

<Layout title="O nás" description="Poznejte firmu Union Power s.r.o. – český výrobce plastových dílů s více než 15 lety zkušeností.">
  <!-- Page Header -->
  <section class="relative bg-primary pt-24 pb-8 md:pt-32 md:pb-16 overflow-hidden">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-accent"></span>
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">O společnosti</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-white tracking-tight">{data.pageTitle}</h1>
      <p class="text-white/80 mt-4 max-w-xl text-lg">
        {data.pageDescription}
      </p>
    </div>
  </section>

  <!-- Company Info -->
  <section class="py-10 md:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="reveal">
          <h2 class="text-3xl md:text-4xl font-black text-primary tracking-tight mb-8">{data.history.heading}</h2>
          <div class="space-y-5 text-gray-medium leading-relaxed">
            {data.history.paragraphs.map(p => (
              <p>{p}</p>
            ))}
          </div>
        </div>

        <div class="reveal reveal-delay-1">
          <div class="rounded-3xl overflow-hidden">
            <img src="/images/o-nas.jpg" alt="Union Power - výrobní hala" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-10 md:py-12 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6 reveal">
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Principy</span>
        <h2 class="text-3xl md:text-4xl font-black text-primary mt-3 tracking-tight">Naše hodnoty</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-3xl p-7 text-center border border-gray-100 hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5 reveal">
          <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg aria-hidden="true" class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary mb-3">Kvalita</h3>
          <p class="text-sm text-gray-medium leading-relaxed">
            Každý výrobek prochází důslednou kontrolou. Kvalita je pro nás nepřekročitelný standard.
          </p>
        </div>

        <div class="bg-white rounded-3xl p-7 text-center border border-gray-100 hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5 reveal reveal-delay-1">
          <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg aria-hidden="true" class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary mb-3">Spolehlivost</h3>
          <p class="text-sm text-gray-medium leading-relaxed">
            Dodržujeme dohodnuté termíny a podmínky. Na naše slovo se můžete spolehnout.
          </p>
        </div>

        <div class="bg-white rounded-3xl p-7 text-center border border-gray-100 hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5 reveal reveal-delay-2">
          <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg aria-hidden="true" class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary mb-3">Partnerství</h3>
          <p class="text-sm text-gray-medium leading-relaxed">
            Individuální přístup ke každému zákazníkovi. Hledáme optimální řešení pro vaše potřeby.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-10 bg-primary overflow-hidden">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl md:text-4xl font-black text-white tracking-tight">Chcete s námi spolupracovat?</h2>
      <p class="text-white/80 max-w-lg mx-auto mt-4">
        Kontaktujte nás a probereme váš projekt. Rádi vám připravíme nabídku na míru.
      </p>
      <a href="/kontakt" class="inline-flex bg-accent text-primary font-semibold px-10 py-4 rounded-full transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/25 text-sm uppercase tracking-wide mt-8 pulse-cta">
        Kontaktujte nás
      </a>
    </div>
  </section>
</Layout>
