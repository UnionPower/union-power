---
import Layout from '../layouts/Layout.astro';
import hp from '../data/homepage.json';
---

<Layout title="Lisování plastů a výroba plastových dílů">
  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center bg-primary overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 grid-pattern"></div>
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-accent/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 -left-32 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 md:pt-36 pb-16 md:pb-20 w-full">
      <div class="max-w-4xl">
        <div class="flex items-center gap-3 mb-4 md:mb-8">
          <span class="w-12 h-px bg-accent"></span>
          <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">{hp.subtitle}</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-8xl font-black text-white leading-[0.95] mb-4 md:mb-8 tracking-tight">
          {hp.heading1}<br>
          {hp.heading2}<br>
          <span class="text-gradient">{hp.heading3}</span>
        </h1>

        <p class="text-base md:text-xl text-white/80 leading-relaxed mb-8 md:mb-12 max-w-xl">
          {hp.description}
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/sluzby" class="group bg-accent text-primary font-semibold px-6 py-3 md:px-8 md:py-4 rounded-full transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/25 text-sm uppercase tracking-wide flex items-center gap-3">
            Naše služby
            <svg aria-hidden="true" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/kontakt" class="border border-white/20 text-white hover:border-accent hover:text-accent font-medium px-6 py-3 md:px-8 md:py-4 rounded-full transition-all duration-300 text-sm uppercase tracking-wide">
            Kontaktujte nás
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative -mt-1 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-primary-light rounded-2xl -mt-12 relative z-10 shadow-2xl shadow-primary/20">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
          {hp.stats.map((stat, i) => (
            <div class={`p-8 text-center reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
              <div class={`text-3xl md:text-4xl font-black ${i === hp.stats.length - 1 ? 'text-white' : 'text-accent'}`}>{stat.value}</div>
              <div class="text-xs text-white/80 mt-2 uppercase tracking-widest">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-6 reveal">
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Služby</span>
        <h2 class="text-4xl md:text-5xl font-black text-primary mt-3 tracking-tight">Co děláme</h2>
        <p class="text-gray-medium mt-4 text-lg">Komplexní řešení v oblasti zpracování plastů od návrhu po hotový výrobek.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {hp.services.map((service, i) => (
          <div class={`bg-surface rounded-3xl p-8 border border-gray-100 hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5 reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
            <h3 class="text-lg font-bold text-primary mb-2">{service.title}</h3>
            <p class="text-gray-medium text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-10 md:py-14 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">O společnosti</span>
          <h2 class="text-4xl md:text-5xl font-black text-primary mt-3 tracking-tight leading-tight" set:html={hp.about.heading.replace('\n', '<br>')} />
          <p class="text-gray-medium leading-relaxed mt-6">
            {hp.about.text}
          </p>
          <div class="flex flex-wrap gap-4 mt-8">
            <a href="/o-nas" class="group inline-flex items-center gap-3 bg-primary text-white font-semibold px-7 py-3.5 rounded-full hover:bg-primary-light transition-all duration-300 text-sm uppercase tracking-wide">
              Více o nás
              <svg aria-hidden="true" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <div class="reveal">
          <div class="rounded-3xl overflow-hidden max-h-[300px] md:max-h-[400px]">
            <img src="/images/hala2.jpg" alt="Výrobní hala Union Power" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal hidden">
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Vlastní nástrojárna</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Kompletní výroba a servis forem</p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Lisy Arburg</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Špičkové vstřikovací technologie</p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Flexibilní výroba</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Od prototypů po velké série</p>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-accent/30 transition-colors duration-300">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h4 class="font-bold text-primary text-sm">Certifikovaná kvalita</h4>
            <p class="text-xs text-gray-medium mt-1.5 leading-relaxed">Kontrola v každé fázi</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6 reveal">
        <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Odvětví</span>
        <h2 class="text-4xl md:text-5xl font-black text-primary mt-3 tracking-tight">Komu dodáváme</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 reveal">
        {hp.industries.map(industry => (
          <div class="text-center p-8 rounded-2xl border border-gray-100 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
            <h3 class="font-bold text-primary text-sm">{industry.title}</h3>
            <p class="text-xs text-gray-medium mt-1">{industry.subtitle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-10 md:py-14 bg-primary overflow-hidden">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent/10 rounded-full blur-[150px]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <span class="text-accent text-sm font-semibold uppercase tracking-[0.2em]">Spolupráce</span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mt-4 tracking-tight">
        Máte projekt?
      </h2>
      <p class="text-white/80 max-w-lg mx-auto mt-6 text-lg">
        Připravíme nezávaznou nabídku.
      </p>
      <a href="/kontakt" class="inline-flex bg-accent text-primary font-semibold px-10 py-4 rounded-full transition-all duration-300 hover:bg-accent-dark hover:shadow-lg hover:shadow-accent/25 text-sm uppercase tracking-wide mt-10 pulse-cta">
        Nezávazná poptávka
      </a>
    </div>
  </section>
</Layout>
